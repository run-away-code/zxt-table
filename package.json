{
  "name": "zxt-table",
  "private": false,
  "version": "0.5.5",
  "type": "module",
  "description": "一个基于 Vue 3 和 Element Plus 的高级表格、表单组件库",
  "keywords": [
    "vue",
    "vue3",
    "table",
    "form",
    "grid",
    "component",
    "element-plus",
    "zxt-table"
  ],
  "author": "",
  "license": "MIT",
  "main": "./dist/zxt-table.umd.js",
  "module": "./dist/zxt-table.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/zxt-table.es.js",
      "require": "./dist/zxt-table.umd.js"
    },
    "./style.css": "./dist/zxt-table.css",
    "./dist/style.css": "./dist/zxt-table.css",
    "./resolver": "./resolver.js"
  },
  "files": [
    "dist",
    "README.md",
    "resolver.js"
  ],
  "release": {
    "branches": [
      "main",
      "master",
      { "name": "v*", "channel": "${name}" }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "element-plus": "^2.0.0",
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "element-plus": "^2.11.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.22"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "vue-router": "^4.6.4"
  }
}
